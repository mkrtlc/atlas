# ─── Atlas Configuration ─────────────────────────────────────────
# Copy to .env and fill in values. The install.sh script does this automatically.

# ─── Required (auto-generated by installer) ──────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
# Must be exactly 64 hex characters (openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=CHANGE_ME

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://atlas:atlas@postgres:5432/atlas
POSTGRES_PASSWORD=atlas

# ─── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# SERVER_PUBLIC_URL=https://atlas.yourdomain.com
# CLIENT_PUBLIC_URL=https://atlas.yourdomain.com
# CORS_ORIGINS=https://atlas.yourdomain.com

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Domain & HTTPS (Caddy auto-provisions Let's Encrypt) ────────
# ATLAS_DOMAIN=atlas.yourdomain.com

# ─── SMTP (optional — also configurable in System > Email UI) ────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Atlas <noreply@yourdomain.com>

# ─── Google OAuth (optional, for CRM email/calendar sync) ────────
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=https://atlas.yourdomain.com/api/v1/auth/google/callback
