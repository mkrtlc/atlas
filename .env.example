# ─── Atlas Configuration ─────────────────────────────────────────

# Required: Generate these secrets before starting
# Run: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Run: openssl rand -hex 32 (must be exactly 64 hex characters)
TOKEN_ENCRYPTION_KEY=CHANGE_ME

# Database password (used by both Atlas and PostgreSQL container)
POSTGRES_PASSWORD=atlas

# ─── Optional ────────────────────────────────────────────────────

# Server port (default: 3001)
# PORT=3001

# Public URLs (set these if running behind a reverse proxy)
# SERVER_PUBLIC_URL=https://atlas.yourdomain.com
# CLIENT_PUBLIC_URL=https://atlas.yourdomain.com

# Google OAuth (for CRM email/calendar sync)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# SMTP (for password reset emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Atlas <noreply@yourdomain.com>
