# Atlas Platform — Local Dev Environment
# Copy to .env and fill in values, then run: docker compose up -d

# Platform runtime (docker for local dev, k8s for production)
PLATFORM_RUNTIME=docker

# Platform PostgreSQL (the docker-compose postgres)
DATABASE_PLATFORM_URL=postgresql://atlas:atlas_dev_password@localhost:5433/atlas_platform

# Addon PostgreSQL admin (same postgres, used to CREATE DATABASE for apps)
ADDON_PG_ADMIN_URL=postgresql://atlas:atlas_dev_password@localhost:5433/postgres

# Addon Redis
ADDON_REDIS_URL=redis://localhost:6379

# OIDC signing key (generate with: ./scripts/generate-oidc-key.sh)
# OIDC_SIGNING_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Public URL (how the browser reaches Atlas)
PLATFORM_PUBLIC_URL=http://localhost:3001

# Redis for BullMQ (same redis as addon)
REDIS_URL=redis://localhost:6379
