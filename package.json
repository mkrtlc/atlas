{
  "name": "atlasmail",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client",
    "packages/desktop"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@atlasmail/client --filter=@atlasmail/server",
    "dev:desktop": "concurrently --kill-others \"npm run dev:web\" \"wait-on http://localhost:5180 && npm run dev --workspace=@atlasmail/desktop\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "packageManager": "npm@10.9.4",
  "overrides": {
    "@tiptap/extension-color": "2.27.2",
    "@tiptap/extension-highlight": "2.27.2",
    "@tiptap/extension-text-style": "2.27.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@preact/signals": "^2.8.1",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/extension-unique-id": "^3.20.0",
    "@types/bcryptjs": "^2.4.6",
    "ag-grid-react": "^35.1.0",
    "bcryptjs": "^3.0.3",
    "temporal-polyfill": "^0.3.0"
  }
}
