{
  "id": "calcom",
  "name": "Cal.com",
  "description": "Open-source scheduling platform — event types, availability, booking pages, and calendar integrations",
  "icon": "CalendarCheck",
  "category": "scheduling",
  "color": "#292929",
  "website": "https://cal.com",
  "license": "AGPL-3.0",
  "supportedPlatforms": ["linux/amd64"],
  "services": {
    "app": {
      "image": "calcom/cal.com:latest",
      "port": 3000,
      "healthCheck": "/",
      "env": {
        "NEXT_PUBLIC_WEBAPP_URL": "$APP_URL",
        "NEXTAUTH_URL": "$APP_URL/api/auth",
        "NEXTAUTH_SECRET": "$SECRET_NEXTAUTH_64",
        "CALENDSO_ENCRYPTION_KEY": "$SECRET_ENCRYPTION_32",
        "DATABASE_URL": "postgresql://calcom:$SECRET_DB_PASS_32@db:5432/calcom",
        "DATABASE_DIRECT_URL": "postgresql://calcom:$SECRET_DB_PASS_32@db:5432/calcom",
        "DATABASE_HOST": "db",
        "NEXT_PUBLIC_LICENSE_CONSENT": "agree",
        "CALCOM_TELEMETRY_DISABLED": "1",
        "NODE_ENV": "production",
        "CSP_POLICY": ""
      },
      "dependsOn": ["db"]
    },
    "db": {
      "image": "postgres:16-alpine",
      "env": {
        "POSTGRES_DB": "calcom",
        "POSTGRES_USER": "calcom",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U calcom"
    }
  },
  "userEnv": [
    {
      "key": "CALCOM_LICENSE_KEY",
      "label": "Cal.com license key (optional, for enterprise features)",
      "required": false
    },
    {
      "key": "EMAIL_FROM",
      "label": "Sender email address for outgoing notifications",
      "required": false,
      "default": "Cal.com <noreply@localhost>"
    },
    {
      "key": "EMAIL_SERVER_HOST",
      "label": "SMTP server address",
      "required": false
    },
    {
      "key": "EMAIL_SERVER_PORT",
      "label": "SMTP server port",
      "required": false,
      "default": "587"
    },
    {
      "key": "EMAIL_SERVER_USER",
      "label": "SMTP username",
      "required": false
    },
    {
      "key": "EMAIL_SERVER_PASSWORD",
      "label": "SMTP password",
      "required": false
    }
  ],
  "resources": { "minRam": "2048MB", "estimatedDisk": "2GB" }
}
