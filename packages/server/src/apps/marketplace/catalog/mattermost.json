{
  "id": "mattermost",
  "name": "Mattermost",
  "description": "Open-source team messaging — channels, threads, and integrations (Slack alternative)",
  "icon": "MessagesSquare",
  "category": "communication",
  "color": "#0058CC",
  "website": "https://mattermost.com",
  "license": "MIT",
  "services": {
    "app": {
      "image": "mattermost/mattermost-team-edition:10.11",
      "platformImages": {
        "linux/arm64": "ghcr.io/supersunho/docker-mattermost/mattermost:latest-team"
      },
      "port": 8065,
      "healthCheck": "/api/v4/system/ping",
      "env": {
        "TZ": "UTC",
        "MM_SQLSETTINGS_DRIVERNAME": "postgres",
        "MM_SQLSETTINGS_DATASOURCE": "postgres://mmuser:$SECRET_DB_PASS_32@db:5432/mattermost?sslmode=disable&connect_timeout=10",
        "MM_BLEVESETTINGS_INDEXDIR": "/mattermost/bleve-indexes",
        "MM_SERVICESETTINGS_SITEURL": "$APP_URL",
        "MM_SERVICESETTINGS_LISTENADDRESS": ":8065",
        "MM_TEAMSETTINGS_ENABLEOPENSERVER": "true",
        "MM_SERVICESETTINGS_ENABLELOCALMODE": "false",
        "MM_LOGSETTINGS_CONSOLELEVEL": "INFO",
        "MM_LOGSETTINGS_ENABLECONSOLE": "true"
      },
      "volumes": [
        "config:/mattermost/config",
        "data:/mattermost/data",
        "logs:/mattermost/logs",
        "plugins:/mattermost/plugins",
        "client-plugins:/mattermost/client/plugins",
        "bleve-indexes:/mattermost/bleve-indexes"
      ],
      "dependsOn": ["db"]
    },
    "db": {
      "image": "postgres:15-alpine",
      "env": {
        "POSTGRES_DB": "mattermost",
        "POSTGRES_USER": "mmuser",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U mmuser -d mattermost"
    }
  },
  "userEnv": [],
  "resources": { "minRam": "512MB", "estimatedDisk": "1GB" }
}
