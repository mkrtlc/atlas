{
  "id": "activepieces",
  "name": "Activepieces",
  "description": "Visual workflow automation — connect your apps and automate tasks",
  "icon": "Workflow",
  "category": "automation",
  "color": "#6e41e2",
  "website": "https://www.activepieces.com",
  "license": "MIT",
  "services": {
    "app": {
      "image": "activepieces/activepieces:latest",
      "port": 80,
      "healthCheck": "/api/v1/flags",
      "env": {
        "AP_EXECUTION_MODE": "UNSANDBOXED",
        "AP_ENVIRONMENT": "prod",
        "AP_FRONTEND_URL": "$APP_URL",
        "AP_WEBHOOK_TIMEOUT_SECONDS": "30",
        "AP_TRIGGER_DEFAULT_POLL_INTERVAL": "5",
        "AP_POSTGRES_DATABASE": "activepieces",
        "AP_POSTGRES_HOST": "db",
        "AP_POSTGRES_PORT": "5432",
        "AP_POSTGRES_USERNAME": "activepieces",
        "AP_POSTGRES_PASSWORD": "$SECRET_DB_PASS_32",
        "AP_REDIS_HOST": "redis",
        "AP_REDIS_PORT": "6379",
        "AP_ENCRYPTION_KEY": "$SECRET_ENCRYPTION_32",
        "AP_JWT_SECRET": "$SECRET_JWT_64"
      },
      "dependsOn": ["db", "redis"]
    },
    "db": {
      "image": "postgres:15-alpine",
      "env": {
        "POSTGRES_DB": "activepieces",
        "POSTGRES_USER": "activepieces",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U activepieces"
    },
    "redis": {
      "image": "redis:7-alpine",
      "volumes": ["redisdata:/data"],
      "healthCheck": "redis-cli ping"
    }
  },
  "userEnv": [],
  "resources": { "minRam": "1024MB", "estimatedDisk": "1GB" }
}
