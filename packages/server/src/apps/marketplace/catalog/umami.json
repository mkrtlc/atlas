{
  "id": "umami",
  "name": "Umami",
  "description": "Privacy-focused web analytics — lightweight alternative to Google Analytics",
  "icon": "BarChart3",
  "category": "analytics",
  "color": "#000000",
  "website": "https://umami.is",
  "license": "MIT",
  "defaultCredentials": { "username": "admin", "password": "umami" },
  "services": {
    "app": {
      "image": "ghcr.io/umami-software/umami:postgresql-latest",
      "port": 3000,
      "healthCheck": "/api/heartbeat",
      "env": {
        "DATABASE_URL": "postgresql://umami:$SECRET_DB_PASS_32@db:5432/umami",
        "APP_SECRET": "$SECRET_APP_KEY_64"
      },
      "dependsOn": ["db"]
    },
    "db": {
      "image": "postgres:15-alpine",
      "env": {
        "POSTGRES_DB": "umami",
        "POSTGRES_USER": "umami",
        "POSTGRES_PASSWORD": "$SECRET_DB_PASS_32"
      },
      "volumes": ["data:/var/lib/postgresql/data"],
      "healthCheck": "pg_isready -U umami"
    }
  },
  "userEnv": [],
  "resources": { "minRam": "512MB", "estimatedDisk": "300MB" }
}
