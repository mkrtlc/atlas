{
  "manifestVersion": 1,
  "id": "com.atlas.mattermost",
  "name": "Mattermost",
  "version": "10.11.1",
  "description": "Open-source team messaging platform with channels, direct messages, file sharing, and integrations.",
  "category": "collaboration",
  "tags": ["messaging", "chat", "team-collaboration"],
  "ui": {
    "icon": "mattermost",
    "color": "#0058CC",
    "screenshots": []
  },
  "runtime": {
    "image": "registry.atlas.so/apps/mattermost:10.11.1",
    "httpPort": 8065,
    "healthCheckPath": "/api/v4/system/ping",
    "healthCheckTimeoutSeconds": 120
  },
  "resources": {
    "memoryMb": 512,
    "cpuMillicores": 500,
    "storageMb": 1024
  },
  "addons": {
    "postgresql": true,
    "redis": false,
    "smtp": false,
    "s3": false
  },
  "persistentDirs": ["/mattermost/data"],
  "sso": {
    "method": "oidc",
    "oidcCallbackPath": "/login/gitlab/complete"
  },
  "lifecycle": {
    "backupCommand": "",
    "restoreCommand": ""
  },
  "provisioning": {
    "adapter": "mattermost",
    "adminApiBasePath": "/api/v4",
    "supportsDeprovisioning": true,
    "roleMapping": {
      "admin": "system_admin",
      "member": "system_user",
      "viewer": "system_user"
    }
  },
  "minPlan": "starter"
}
